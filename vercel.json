{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/webhook.py": { "maxDuration": 30 },
    "api/cron.py": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron?task=expire", "schedule": "*/30 * * * *" },
    { "path": "/api/cron?task=antifraud", "schedule": "*/15 * * * *" },
    { "path": "/api/cron?task=payments", "schedule": "*/10 * * * *" },
    { "path": "/api/cron?task=reminders", "schedule": "0 9 * * *" }
  ]
}
